# ─── .env ────────────────────────────────────────────────────────────────────
# Variables de entorno — NO subir al repositorio (está en .gitignore)
# Copiar este archivo como .env y completar los valores reales

# Puerto del servidor
PORT=3000

# Conexión a MongoDB
# Desarrollo local:
MONGO_URI=mongodb://localhost:27017/todostock
# Producción (Mongo Atlas) — reemplazar con la URI real del cluster:
# MONGO_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/todostock?retryWrites=true&w=majority

# Clave de sesión para la cookie de autenticación
SESSION_KEY=todostock_session

# Credenciales del panel web (en producción usar hash — ver auth.middleware.js)
ADMIN_USER=user
ADMIN_PASSWORD=user1234

# Entorno (development | production)
NODE_ENV=development
