# ─── .env ─────────────────────────────────────────────────────────────────────
# Variables de entorno — NO subir al repositorio (está en .gitignore)
# Copiar este archivo como .env y completar los valores reales

# Puerto del servidor
PORT=3000

# Conexión a MongoDB
# Desarrollo local:
MONGO_URI=mongodb://localhost:27017/todostock
# Producción (Mongo Atlas):
# MONGO_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/todostock?retryWrites=true&w=majority

# Clave de sesión para la cookie de autenticación
SESSION_KEY=todostock_session

# JWT y Refresh Tokens
JWT_SECRET=todostock_jwt_secret_2026
JWT_EXPIRES=1h
REFRESH_SECRET=todostock_refresh_secret_2026
REFRESH_EXPIRES=7d

# ── ROLES ─────────────────────────────────────────────────────────────────────
# Administrador — acceso total al sistema
ADMIN_USER=user
ADMIN_PASSWORD=user1234

# Empleado — acceso restringido (no ve proveedores, resumen ni auditoría)
EMPLEADO_USER=empleado
EMPLEADO_PASSWORD=emp1234

# Entorno
NODE_ENV=development
