doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title TodoStock — Dashboard
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, sans-serif; background: #f0f2f5; padding: 24px 20px; }
      .wrap { max-width: 860px; margin: 0 auto; }
      .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
      h1 { font-size: 1.4em; color: #1a252f; }
      a.volver { font-size: .85em; color: #666; text-decoration: none; border: 1px solid #ddd; padding: 5px 12px; border-radius: 5px; }
      a.volver:hover { background: #f5f5f5; }
      .cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 24px; }
      .card { background: white; border-radius: 10px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,.07); }
      .card .val { font-size: 2em; font-weight: bold; color: #1a252f; }
      .card .lbl { font-size: .82em; color: #888; margin-top: 2px; }
      .card .sub { font-size: .78em; color: #aaa; margin-top: 4px; }
      .alertas h2 { font-size: 1em; font-weight: bold; color: #1a252f; margin-bottom: 12px; }
      .alerta { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; margin-bottom: 8px; font-size: .9em; }
      .ALTA   { background: #fef2f2; border-left: 4px solid #ef4444; color: #991b1b; }
      .MEDIA  { background: #fffbeb; border-left: 4px solid #f59e0b; color: #92400e; }
      .sin-alertas { color: #16a34a; font-size: .95em; padding: 12px; background: #f0fdf4; border-radius: 8px; }
      .generado { font-size: .75em; color: #aaa; margin-top: 16px; text-align: right; }

  body
    div.wrap
      div.top
        h1 📊 Dashboard Resumen
        a.volver(href="/") ← Volver al panel

      div.cards
        div.card
          div.val= datos.proveedores.activos
          div.lbl Proveedores activos
          div.sub= datos.proveedores.inactivos + ' inactivos'
        div.card
          div.val= datos.productos.activos
          div.lbl Productos activos
          div.sub= datos.productos.sinStock + ' sin stock · ' + datos.productos.enStockMinimo + ' en mínimo'
        div.card
          div.val= '$' + datos.clientes.deudaTotalCartera.toLocaleString()
          div.lbl Deuda total cartera
          div.sub= datos.clientes.conDeudaAlta + ' clientes con deuda alta'
        div.card
          div.val= datos.ventas.hoy
          div.lbl Ventas hoy
          div.sub= '$' + datos.ventas.totalHoy.toLocaleString() + ' facturado hoy'

      div.alertas
        h2 Alertas activas (#{datos.alertas.total})
        if datos.alertas.total === 0
          p.sin-alertas ✅ Sin alertas activas — el sistema está operando con normalidad.
        else
          each alerta in datos.alertas.items
            div(class="alerta " + alerta.urgencia)
              span= alerta.urgencia === 'ALTA' ? '🔴' : '🟡'
              span #{alerta.tipo} — #{alerta.mensaje}

      p.generado Generado: #{new Date(datos.generadoEn).toLocaleString('es-AR')}
