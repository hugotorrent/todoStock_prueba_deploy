doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title TodoStock — Ventas
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, sans-serif; background: #f0f2f5; padding: 24px 20px; }
      .wrap { max-width: 900px; margin: 0 auto; }
      .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
      h1 { font-size: 1.4em; color: #1a252f; }
      a.volver { font-size: .85em; color: #666; text-decoration: none; border: 1px solid #ddd; padding: 5px 12px; border-radius: 5px; }
      .info-rol { font-size: .82em; padding: 8px 12px; border-radius: 6px; margin-bottom: 16px; }
      .info-admin { background: #ede9fe; color: #4c1d95; }
      .info-emp   { background: #d1fae5; color: #065f46; }
      table { width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.07); }
      th { background: #1a252f; color: white; padding: 12px 14px; text-align: left; font-size: .85em; }
      td { padding: 11px 14px; border-bottom: 1px solid #f0f0f0; font-size: .9em; }
      tr:last-child td { border-bottom: none; }
      .badge { font-size: .75em; padding: 3px 8px; border-radius: 99px; font-weight: 600; }
      .confirmada { background: #dcfce7; color: #16a34a; }
      .cancelada  { background: #fef2f2; color: #991b1b; }
      .btn-sm { font-size: .78em; padding: 3px 8px; border-radius: 4px; border: 1px solid #fca5a5; cursor: pointer; background: white; color: #dc2626; }

  body
    div.wrap
      div.top
        h1 🧾 Ventas
        a.volver(href="/") ← Volver

      if rol === 'admin'
        p.info-rol.info-admin 👑 Administrador — podés ver, registrar y cancelar ventas. Usá Postman para crear ventas con validación completa.
      else
        p.info-rol.info-emp 👤 Empleado — podés ver el historial. Para registrar ventas usá la colección Postman disponible en tools/.

      table
        thead
          tr
            th Cliente
            th Modalidad
            th Total
            th Estado
            th Fecha
            th Items
            if rol === 'admin'
              th Acciones

        tbody
          if ventas.length === 0
            tr
              td(colspan="7" style="text-align:center;color:#aaa;padding:24px") No hay ventas registradas aún.
          else
            each v in ventas
              tr
                td= v.clienteId?.razonSocial || '—'
                td= v.modalidad
                td= '$' + v.total.toLocaleString()
                td
                  span(class="badge " + v.estado)= v.estado
                td= new Date(v.createdAt).toLocaleDateString('es-AR')
                td= v.items.length + ' producto(s)'
                if rol === 'admin'
                  td
                    if v.estado === 'confirmada'
                      button.btn-sm Cancelar
                    else
                      span(style="color:#aaa;font-size:.8em") —
