doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title TodoStock S.A. - Panel
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, sans-serif; background: #f0f2f5; padding: 32px 20px; }
      .contenedor { background: white; padding: 36px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,.1); max-width: 520px; margin: 0 auto; }
      .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px; }
      h1 { color: #1a252f; font-size: 1.8em; }
      .rol-badge { font-size: .75em; font-weight: 700; padding: 4px 12px; border-radius: 99px; }
      .rol-admin { background: #ede9fe; color: #4c1d95; }
      .rol-empleado { background: #d1fae5; color: #065f46; }
      .subtitulo { color: #666; margin-bottom: 28px; font-size: 1em; }
      .alerta-acceso { background: #fef2f2; border-left: 4px solid #ef4444; padding: 10px 14px; border-radius: 0 6px 6px 0; margin-bottom: 20px; font-size: .9em; color: #991b1b; }
      .menu { display: flex; flex-direction: column; gap: 10px; margin-bottom: 32px; }
      .boton { padding: 14px; font-size: 1em; text-decoration: none; color: #111; border-radius: 6px; border: 1px solid #2f2e2e; font-weight: bold; background: #fff; transition: background .2s; display: block; }
      .boton:hover { background: #f0f2f5; }
      .boton-bloqueado { opacity: .4; pointer-events: none; border-style: dashed; }
      .btn-logout { font-size: .82em; color: #999; text-decoration: none; border: 1px solid #ddd; padding: 5px 12px; border-radius: 5px; }
      .btn-logout:hover { background: #f5f5f5; }
      footer { margin-top: 20px; font-size: .82em; color: #999; text-align: center; }

  body
    div.contenedor
      div.header
        div
          h1 TodoStock S.A.
          p.subtitulo Panel de Administración
        div(style="display:flex;flex-direction:column;align-items:flex-end;gap:8px")
          if rol === 'admin'
            span.rol-badge.rol-admin 👑 Administrador
          else
            span.rol-badge.rol-empleado 👤 Empleado
          a.btn-logout(href="/logout") Cerrar sesión

      if accesoDenegado
        div.alerta-acceso ⛔ No tenés permisos para acceder a esa sección.

      div.menu
        a.boton(href="/ventas") 🧾 Registro de Ventas
        a.boton(href="/productos") 📦 Productos
        a.boton(href="/clientes") 👤 Clientes

        if rol === 'admin'
          a.boton(href="/proveedores") 🏭 Proveedores
          a.boton(href="/resumen") 📊 Dashboard Resumen
          a.boton(href="/auditoria") 🗂 Auditoría
        else
          a.boton.boton-bloqueado(href="#") 🏭 Proveedores 🔒
          a.boton.boton-bloqueado(href="#") 📊 Dashboard Resumen 🔒
          a.boton.boton-bloqueado(href="#") 🗂 Auditoría 🔒

      footer © DHL Solutions — Grupo N°9
