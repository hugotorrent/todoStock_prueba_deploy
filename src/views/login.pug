doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title TodoStock S.A. - Iniciar Sesión
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: Arial, sans-serif;
        background-color: #f0f2f5;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
      }
      .login-card {
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.12);
        width: 100%;
        max-width: 380px;
        text-align: center;
      }
      .logo { font-size: 2.2em; font-weight: bold; color: #1a252f; margin-bottom: 4px; }
      .subtitulo { color: #666; font-size: 0.95em; margin-bottom: 32px; }
      .form-grupo { text-align: left; margin-bottom: 18px; }
      label { display: block; font-size: 0.85em; font-weight: bold; color: #444; margin-bottom: 6px; }
      input {
        width: 100%;
        padding: 11px 14px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 1em;
        transition: border-color 0.2s;
        outline: none;
      }
      input:focus { border-color: #1a252f; }
      .btn-login {
        width: 100%;
        padding: 13px;
        background-color: #1a252f;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 1em;
        font-weight: bold;
        cursor: pointer;
        margin-top: 8px;
        transition: background-color 0.2s;
      }
      .btn-login:hover { background-color: #2c3e50; }
      .error {
        background-color: #ffeaea;
        color: #c0392b;
        border: 1px solid #f5c6c6;
        border-radius: 6px;
        padding: 10px 14px;
        margin-bottom: 18px;
        font-size: 0.9em;
        text-align: left;
      }
      .footer-login { margin-top: 24px; font-size: 0.8em; color: #999; }

  body
    div.login-card
      div.logo TodoStock S.A.
      p.subtitulo Panel de Administración

      if error
        div.error ⚠️ #{error}

      form(action="/login" method="POST")
        div.form-grupo
          label(for="usuario") Usuario
          input(
            type="text"
            id="usuario"
            name="usuario"
            placeholder="Ingresá tu usuario"
            autocomplete="username"
            required
          )
        div.form-grupo
          label(for="password") Contraseña
          input(
            type="password"
            id="password"
            name="password"
            placeholder="••••••••"
            autocomplete="current-password"
            required
          )
        button.btn-login(type="submit") Iniciar Sesión

      p.footer-login © DHL Solutions — Grupo N°9
